<Window x:Class="GestaoAulas.Views.AnalisesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Title="📊 Análises e Relatórios"
        Height="720" Width="1050"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Background="#0a0b10" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="📊 Análises e Relatórios"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="txtSubtitulo"
                               Text="Visão geral dos seus registros"
                               Foreground="#94a3b8"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTEÚDO -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel>
                
                <!-- Resumo Geral -->
                <Border Margin="0,0,0,20" Padding="20" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="RESUMO GERAL" FontWeight="Bold" Foreground="#a78bfa" FontSize="14" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Total de Registros" Foreground="#94a3b8" FontSize="12"/>
                                <TextBlock x:Name="txtTotalRegistros" Text="0" FontWeight="Bold" FontSize="24" Foreground="White" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,12,0">
                                <TextBlock Text="Receita Total" Foreground="#94a3b8" FontSize="12"/>
                                <TextBlock x:Name="txtReceitaTotal" Text="R$ 0,00" FontWeight="Bold" FontSize="24" Foreground="#10b981" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="12,0,12,0">
                                <TextBlock Text="Total Pendente" Foreground="#94a3b8" FontSize="12"/>
                                <TextBlock x:Name="txtTotalPendente" Text="R$ 0,00" FontWeight="Bold" FontSize="24" Foreground="#f97316" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="12,0,0,0">
                                <TextBlock Text="Ticket Médio" Foreground="#94a3b8" FontSize="12"/>
                                <TextBlock x:Name="txtTicketMedio" Text="R$ 0,00" FontWeight="Bold" FontSize="24" Foreground="#3b82f6" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Gráficos: Receita Mensal + Distribuição por Categoria -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Receita por Mês -->
                    <Border Grid.Column="0" Margin="0,0,10,0" Padding="20" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="RECEITA POR MÊS" FontWeight="Bold" Foreground="#a78bfa" FontSize="14" Margin="0,0,0,12"/>
                            <lvc:CartesianChart x:Name="chartReceitaMensal" Height="250"/>
                        </StackPanel>
                    </Border>

                    <!-- Distribuição por Categoria -->
                    <Border Grid.Column="1" Margin="10,0,0,0" Padding="20" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="DISTRIBUIÇÃO POR CATEGORIA" FontWeight="Bold" Foreground="#a78bfa" FontSize="14" Margin="0,0,0,12"/>
                            <lvc:PieChart x:Name="chartCategoria" Height="250"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Gráficos: Status + Top Clientes -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status: Pendente vs Pago -->
                    <Border Grid.Column="0" Margin="0,0,10,0" Padding="20" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="PENDENTE vs PAGO" FontWeight="Bold" Foreground="#a78bfa" FontSize="14" Margin="0,0,0,12"/>
                            <lvc:PieChart x:Name="chartStatus" Height="250"/>
                        </StackPanel>
                    </Border>

                    <!-- Top Clientes/Serviços por Valor -->
                    <Border Grid.Column="1" Margin="10,0,0,0" Padding="20" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="TOP 10 CLIENTES POR VALOR" FontWeight="Bold" Foreground="#a78bfa" FontSize="14" Margin="0,0,0,12"/>
                            <lvc:CartesianChart x:Name="chartTopClientes" Height="250"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Fechar" 
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="White"
                        BorderBrush="#475569"
                        Click="Fechar_Click"
                        Width="110"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
