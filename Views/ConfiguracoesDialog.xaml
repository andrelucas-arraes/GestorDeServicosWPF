<Window x:Class="GestaoAulas.Views.ConfiguracoesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Configurações"
        Height="480" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Background="#0a0b10" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="24,20">
            <TextBlock Text="Configurações"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"/>
        </Border>

        <!-- Conteúdo -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel>

                <!-- Seção: Gerenciar Categorias -->
                <Border Margin="0,0,0,20" Padding="16" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Gerenciar Categorias"
                                   FontWeight="Bold"
                                   Foreground="#94a3b8"
                                   FontSize="14"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Adicione ou remova categorias disponíveis para seus serviços e aulas."
                                   Foreground="#64748b"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <!-- Lista de categorias -->
                        <ListBox x:Name="lstCategorias"
                                 MaxHeight="120"
                                 Background="#0d1117"
                                 Foreground="White"
                                 BorderBrush="#334155"
                                 BorderThickness="1"
                                 Margin="0,0,0,12"/>

                        <!-- Adicionar nova -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtNovaCategoria"
                                     Grid.Column="0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Foreground="White"
                                     BorderBrush="#334155"
                                     materialDesign:HintAssist.Hint="Nova categoria..."
                                     MaxLength="30"/>

                            <Button Grid.Column="1"
                                    Content="Adicionar"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="#22c55e"
                                    BorderBrush="#22c55e"
                                    Height="40"
                                    Click="AdicionarCategoria_Click"
                                    Margin="8,0,0,0"/>

                            <Button Grid.Column="2"
                                    Content="Remover"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="#ef4444"
                                    BorderBrush="#ef4444"
                                    Height="40"
                                    Click="RemoverCategoria_Click"
                                    Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Seção: Backup -->
                <Border Margin="0,0,0,20" Padding="16" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Backup de Dados"
                                   FontWeight="Bold"
                                   Foreground="#94a3b8"
                                   FontSize="14"
                                   Margin="0,0,0,16"/>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock x:Name="txtInfoBanco"
                                       Text="Banco de dados: --"
                                       Foreground="#cbd5e1"/>
                            <TextBlock x:Name="txtUltimoBackup"
                                       Text="Último backup: --"
                                       Foreground="#cbd5e1"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Fazer Backup Agora"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="White"
                                    BorderBrush="#3b82f6"
                                    Height="40"
                                    Click="FazerBackup_Click"
                                    Margin="0,0,12,0"/>
                            <Button Content="Restaurar Backup"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="#f8fafc"
                                    BorderBrush="#475569"
                                    Height="40"
                                    Click="RestaurarBackup_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Seção: Backup Externo -->
                <Border Margin="0,0,0,20" Padding="16" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Backup Externo / Nuvem"
                                   FontWeight="Bold"
                                   Foreground="#94a3b8"
                                   FontSize="14"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Configure uma pasta sincronizada (OneDrive, Google Drive, Dropbox) para backup automático."
                                   TextWrapping="Wrap"
                                   Foreground="#94a3b8"
                                   FontSize="12"
                                   Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtCaminhoExterno"
                                     Grid.Column="0"
                                     IsReadOnly="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Foreground="White"
                                     BorderBrush="#334155"
                                     materialDesign:HintAssist.Hint="Caminho da pasta"/>
                            
                            <Button Grid.Column="1"
                                    Content="Selecionar"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="White"
                                    BorderBrush="#334155"
                                    Click="SelecionarPastaExterna_Click"
                                    Margin="12,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Seção: Atualização -->
                <Border Margin="0,0,0,20" Padding="16" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Atualizar Sistema"
                                   FontWeight="Bold"
                                   Foreground="#94a3b8"
                                   FontSize="14"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Procura por uma nova versão compilada e atualiza o aplicativo atual."
                                   TextWrapping="Wrap"
                                   Foreground="#94a3b8"
                                   FontSize="12"
                                   Margin="0,0,0,16"/>

                        <Button Content="Buscar e Atualizar"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="#3b82f6"
                                BorderBrush="#3b82f6"
                                HorizontalAlignment="Left"
                                Height="40"
                                Click="AtualizarAplicativo_Click"/>
                    </StackPanel>
                </Border>

                <!-- Seção: Sobre -->
                <Border Padding="16" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Sobre"
                                   FontWeight="Bold"
                                   Foreground="#94a3b8"
                                   FontSize="14"
                                   Margin="0,0,0,12"/>
                        
                        <TextBlock Text="Gestor de Serviços"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock x:Name="txtVersao" 
                                   Text="Pesquisando Versão..."
                                   Foreground="#94a3b8"/>
                        <TextBlock Text="Desenvolvido em C# / .NET 8"
                                   Foreground="#94a3b8"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Botões -->
        <Border Grid.Row="2" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Fechar" 
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="White"
                        BorderBrush="#475569"
                        Click="Fechar_Click"
                        Width="110"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
