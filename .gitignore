## Complete .gitignore for WPF/C# (.NET 8) Projects

# =============================================================================
# Build Results
# =============================================================================
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
msbuild.log
msbuild.err
msbuild.wrn

# =============================================================================
# Project-Specific Outputs
# =============================================================================
publish/
publish_portable/
publish_standalone/
Export/
[Ll]og/
[Ll]ogs/
*.log

# Temp/scratch files
test.cs
*.tmp
*.bak
*~

# =============================================================================
# Visual Studio
# =============================================================================
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo
*.rsuser
*.cache
*.opendb
*.db-shm
*.db-wal
*.sln.iml

# Visual Studio auto-generated files
Generated\ Files/

# Crash logs
ServiceFabricApplications.log

# =============================================================================
# Visual Studio Code
# =============================================================================
.vscode/
*.code-workspace

# =============================================================================
# JetBrains (Rider / ReSharper)
# =============================================================================
.idea/
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# =============================================================================
# NuGet
# =============================================================================
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json

# =============================================================================
# MSTest / Unit Testing
# =============================================================================
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml

# =============================================================================
# Databases (SQLite)
# =============================================================================
*.db
*.sqlitedb
*.sqlite
*.db-journal

# =============================================================================
# Mono / Xamarin
# =============================================================================
*.userprefs
mono_crash.*

# =============================================================================
# OS-Specific Files
# =============================================================================

# Windows
Thumbs.db
Thumbs.db:encryptable
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# Linux
*~
.directory
.Trash-*

# =============================================================================
# Application Data / User Settings
# =============================================================================
backup_config.txt
DevData/

# =============================================================================
# Gemini / AI Assistants
# =============================================================================
.gemini/
.agent/
.agents/
_agent/
_agents/
